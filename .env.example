# apidoc environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# Target upstream server
APIDOC_TARGET=http://localhost:3000

# Proxy listen address
APIDOC_PROXY_ADDR=:9999

# Docs server listen address
APIDOC_UI_ADDR=:7878

# API title shown in the generated spec
APIDOC_TITLE=My API

# SDK middlewares — set these in your app's environment
APIDOC_ENABLED=true
APIDOC_ENDPOINT=http://localhost:7878
APIDOC_CAPTURE_BODIES=true
