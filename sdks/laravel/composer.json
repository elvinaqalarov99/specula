{
  "name": "spectra/laravel",
  "description": "Zero-config Laravel middleware that auto-generates live API docs",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "openapi", "swagger", "api-docs", "spectra"],
  "authors": [
    {
      "name": "Elvin Agalarov",
      "homepage": "https://github.com/elvinaqalarov99/spectra"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Spectra\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Spectra\\Laravel\\SpectraServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
