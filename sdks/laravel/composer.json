{
  "name": "specula/laravel",
  "description": "Zero-config Laravel middleware that auto-generates live API docs",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "openapi", "swagger", "api-docs", "specula"],
  "authors": [
    {
      "name": "Elvin Agalarov",
      "homepage": "https://github.com/elvinaqalarov99"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^9.0|^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Specula\\Laravel\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Specula\\Laravel\\SpeculaServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "support": {
    "issues": "https://github.com/elvinaqalarov99/specula-laravel/issues",
    "source": "https://github.com/elvinaqalarov99/specula-laravel"
  }
}
